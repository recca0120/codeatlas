---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.svelte";
import LocaleSwitcher from "../components/LocaleSwitcher.svelte";
import { buildUrl } from "../lib/url";
import { t, type Locale } from "../i18n";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  breadcrumb?: { label: string; href: string }[];
  locale?: string;
}

const { title, description = "Global Developer Rankings", ogImage, breadcrumb = [], locale: localeProp } = Astro.props;
const locale = (localeProp ?? Astro.currentLocale ?? "en") as Locale;
const url = Astro.url.href;
const siteOrigin = (Astro.site?.toString() ?? "").replace(/\/$/, "");
const basePath = import.meta.env.BASE_URL;
const ogImageUrl = ogImage ? `${siteOrigin}${ogImage}` : `${siteOrigin}${buildUrl("og.jpg", basePath)}`;
---

<html lang={locale === "zh-TW" ? "zh-TW" : "en"}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={buildUrl("favicon.svg", basePath)} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preload" href={buildUrl("fonts/SpaceGrotesk-Bold.woff", basePath)} as="font" type="font/woff" crossorigin />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:image" content={ogImageUrl} />
    <script is:inline>
      document.documentElement.classList.toggle("dark",
        localStorage.theme==="dark"||(!("theme" in localStorage)&&matchMedia("(prefers-color-scheme:dark)").matches));
    </script>
    <script is:inline define:vars={{ basePath }}>
      // Locale preference redirect: if user has a saved locale and is on the wrong version, redirect
      (function() {
        var saved = localStorage.getItem("locale");
        if (!saved) return;
        var path = window.location.pathname;
        var base = basePath.endsWith("/") ? basePath.slice(0, -1) : basePath;
        var isZhTW = path.startsWith(base + "/zh-TW");
        if (saved === "zh-TW" && !isZhTW) {
          var rest = path.slice(base.length);
          window.location.replace(base + "/zh-TW" + rest);
        } else if (saved === "en" && isZhTW) {
          var rest = path.slice((base + "/zh-TW").length);
          window.location.replace(base + (rest || "/"));
        }
      })();
    </script>
  </head>
  <body class="bg-bg text-text font-body antialiased min-h-screen">

    <nav class="sticky top-0 z-50 w-full bg-bg/90 backdrop-blur-md border-b border-border">
      <div class="w-full px-5 sm:px-8 h-14 flex items-center gap-4">
        <div class="flex items-center gap-2 text-base shrink-0">
          <a href={buildUrl("", basePath)} class="font-display font-bold text-lg text-accent hover:text-accent-hover transition-colors">{t("nav.home", locale)}</a>
          {breadcrumb.map(b => (
            <><span class="text-text-muted">›</span><a href={b.href} class="text-text-secondary hover:text-text transition-colors truncate max-w-[150px] sm:max-w-none">{b.label}</a></>
          ))}
        </div>
        <div class="flex-1"></div>
        <div class="flex items-center gap-4">
          <a href={buildUrl(locale === "zh-TW" ? "zh-TW/faq" : "faq", basePath)} class="text-sm text-text-secondary hover:text-text transition-colors hidden sm:block">{t("nav.faq", locale)}</a>
          <LocaleSwitcher client:load locale={locale} basePath={basePath} currentPath={Astro.url.pathname} />
          <ThemeToggle client:load />
          <a href="https://github.com/recca0120/codeatlas" target="_blank" rel="noopener" class="text-text-muted hover:text-text transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </nav>

    <slot />
  </body>
</html>
