---
import Layout from "../../layouts/Layout.astro";
import AppRouter from "../../components/AppRouter.svelte";
import type { Locale } from "../../i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
---

<Layout title="CodeAtlas" locale={locale}>
  <AppRouter client:only="svelte" basePath={import.meta.env.BASE_URL} locale={locale} />
</Layout>
