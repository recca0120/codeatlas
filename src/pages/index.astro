---
import Layout from "../layouts/Layout.astro";
import AppRouter from "../components/AppRouter.svelte";
import type { Locale } from "../i18n";
import { t } from "../i18n";

const locale = (Astro.currentLocale ?? "en") as Locale;
const basePath = import.meta.env.BASE_URL;
---

<Layout title={`CodeAtlas — ${t("hero.title", locale)}`} locale={locale}>
  <AppRouter client:only="svelte" {basePath} {locale} />
</Layout>
